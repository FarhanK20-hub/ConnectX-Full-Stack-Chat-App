# ════════════════════════════════════
# CONNECTX — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit your .env file to version control
# Rotate all secrets before deploying to production
# ════════════════════════════════════

# ── App ──────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database ─────────────────────────
# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/connectx
# Local:         mongodb://localhost:27017/connectx
MONGODB_URI=mongodb://localhost:27017/connectx

# ── JWT Secrets ───────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use DIFFERENT values for access and refresh secrets
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Vault JWT ─────────────────────────
VAULT_JWT_SECRET=replace_with_another_64_char_random_hex_string
VAULT_JWT_EXPIRY=15m

# ── Cloudinary ────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Anthropic Claude ──────────────────
# Get from: https://console.anthropic.com
# Used for: link preview AI summaries
CLAUDE_API_KEY=sk-ant-api03-replace-with-real-key

# ── Spotify OAuth ─────────────────────
# Get from: https://developer.spotify.com/dashboard
# Set redirect URI in dashboard to match SPOTIFY_REDIRECT_URI exactly
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/integrations/spotify/callback

# ── Security ──────────────────────────
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Web Push Notifications (optional) ─
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your@email.com

# ── Cron ─────────────────────────────
# Used to secure any manually-triggered cron endpoints
CRON_SECRET=replace_with_random_string
